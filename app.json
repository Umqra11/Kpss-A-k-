{
  "expo": {
    "name": "kpss-aski",
    "slug": "kpss-aski",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#09090F",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "fetch",
          "processing",
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#09090F",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "KPSS Aşkı",
      "shortName": "KPSS Aşkı",
      "description": "KPSS çalışma süresi takip uygulaması - Arkadaşlarınla rekabet et!",
      "themeColor": "#09090F",
      "backgroundColor": "#09090F",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": [
      "expo-font",
      "expo-splash-screen",
      "expo-task-manager"
    ],
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}