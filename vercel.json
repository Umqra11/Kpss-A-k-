{
    "buildCommand": "npx expo export --platform web --output-dir dist",
    "outputDirectory": "dist",
    "devCommand": "npx expo start --web",
    "rewrites": [
        {
            "source": "/((?!.*\\.).*)",
            "destination": "/index.html"
        },
        {
            "source": "/",
            "destination": "/index.html"
        }
    ]
}